# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Optional real AI. If empty, fallback generator still works.
OPENAI_API_KEY=""
# OPENAI_MODEL is optional. If omitted, code uses gpt-4o-mini.
# OPENAI_MODEL="gpt-4o-mini"

# Optional admin protection. If set, use /dashboard/review?admin=YOUR_SECRET
ADMIN_SECRET=""

# v0.9 generation limits
FREE_DAILY_GENERATIONS=3
CREATOR_DAILY_GENERATIONS=25
PRO_DAILY_GENERATIONS=100

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_VERSION=20
